{
  "version": "2026-05-25",
  "coreCommands": {
    "discuss-phase": {
      "artifacts": [
        ".planning/phases/<phase>/<phase-number>-DISCUSSION-LOG.md",
        ".planning/phases/<phase>/CONTEXT.md"
      ],
      "requiredReads": [
        ".planning/PROJECT.md",
        ".planning/REQUIREMENTS.md",
        ".planning/ROADMAP.md",
        ".planning/STATE.md"
      ],
      "allowedWrites": [
        ".planning/phases/<phase>/<phase-number>-DISCUSSION-LOG.md",
        ".planning/phases/<phase>/CONTEXT.md"
      ],
      "forbiddenWrites": [
        ".git/**",
        ".github/**",
        "node_modules/**",
        "vendor/**"
      ],
      "transitions": [
        {
          "from": "planned",
          "to": "phase-context-ready",
          "when": "Phase context discussion is captured before planning for planner consumption.",
          "notes": "Reference uses a pre-plan CONTEXT.md discussion artifact; bridge writes .planning/phases/<phase>/CONTEXT.md as the canonical adapted path."
        }
      ],
      "flags": [
        {
          "name": "--all",
          "effects": [
            "changesDiscussionScope"
          ],
          "notes": [
            "Reference argument hint lists all-phase discussion mode; bridge parity behavior is unresolved."
          ]
        },
        {
          "name": "--analyze",
          "effects": [
            "changesDiscussionMode"
          ],
          "notes": [
            "Reference argument hint lists analysis-oriented discussion mode."
          ]
        },
        {
          "name": "--assumptions",
          "effects": [
            "loadsAssumptionWorkflow"
          ],
          "notes": [
            "Reference routes to an assumptions workflow when present."
          ]
        },
        {
          "name": "--auto",
          "effects": [
            "reducesInteractivePrompts"
          ],
          "notes": [
            "Reference argument hint lists automatic discussion mode."
          ]
        },
        {
          "name": "--batch",
          "effects": [
            "changesDiscussionMode"
          ],
          "notes": [
            "Reference argument hint lists batch discussion mode."
          ]
        },
        {
          "name": "--chain",
          "effects": [
            "chainsNextWorkflowStep"
          ],
          "notes": [
            "Reference argument hint lists chained discussion mode."
          ]
        },
        {
          "name": "--power",
          "effects": [
            "loadsPowerWorkflow"
          ],
          "notes": [
            "Reference lazily loads the power workflow when this flag is present."
          ]
        },
        {
          "name": "--text",
          "effects": [
            "usesTextInterface"
          ],
          "notes": [
            "Reference argument hint lists text interface mode."
          ]
        }
      ]
    },
    "execute-phase": {
      "artifacts": [
        ".planning/phases/<phase>/<phase-number>-SUMMARY.md",
        ".planning/phases/<phase>/EXECUTION.md"
      ],
      "requiredReads": [
        ".planning/phases/<phase>/CONTEXT.md",
        ".planning/phases/<phase>/PLAN.md"
      ],
      "allowedWrites": [
        ".agents/**",
        ".planning/ROADMAP.md",
        ".planning/STATE.md",
        ".planning/phases/<phase>/<phase-number>-SUMMARY.md",
        ".planning/phases/<phase>/EXECUTION.md",
        "RISKS_UNKNOWNS.md",
        "assets/**",
        "docs/planning/**",
        "docs/reference-compatibility.md",
        "src/**",
        "tests/**"
      ],
      "forbiddenWrites": [
        ".git/**",
        ".github/**",
        "node_modules/**",
        "vendor/**"
      ],
      "transitions": [
        {
          "from": "phase-planned",
          "to": "phase-executed",
          "when": "All required phase implementation work has execution evidence.",
          "notes": "Selected-wave execution should not imply full phase completion while incomplete plans remain."
        }
      ],
      "flags": [
        {
          "name": "--gaps-only",
          "effects": [
            "executesGapClosureOnly",
            "requiresVerificationGaps"
          ],
          "notes": [
            "Reference executes only gap-closure plans after verify-work creates fix plans."
          ]
        },
        {
          "name": "--interactive",
          "effects": [
            "usesInlineExecution",
            "requiresUserCheckpoints"
          ],
          "notes": [
            "Reference executes plans sequentially inline with user checkpoints."
          ]
        },
        {
          "name": "--tdd",
          "effects": [
            "prioritizesTestFirstExecution"
          ],
          "notes": [
            "Reference argument hint lists TDD execution mode."
          ]
        },
        {
          "name": "--wave",
          "effects": [
            "executesSelectedWaveOnly"
          ],
          "notes": [
            "Reference executes only the selected wave and should complete the phase only when no incomplete plans remain."
          ]
        }
      ]
    },
    "map-codebase": {
      "artifacts": [
        ".planning/codebase/ARCHITECTURE.md",
        ".planning/codebase/CONCERNS.md",
        ".planning/codebase/CONVENTIONS.md",
        ".planning/codebase/INTEGRATIONS.md",
        ".planning/codebase/STACK.md",
        ".planning/codebase/STRUCTURE.md",
        ".planning/codebase/TESTING.md"
      ],
      "requiredReads": [
        ".planning/STATE.md",
        "README.md",
        "package.json"
      ],
      "allowedWrites": [
        ".planning/codebase/**"
      ],
      "forbiddenWrites": [
        ".git/**",
        ".github/**",
        "node_modules/**",
        "vendor/**"
      ],
      "transitions": [
        {
          "from": "init",
          "to": "mapped",
          "when": "The seven codebase map documents exist under .planning/codebase/.",
          "notes": "Reference full map uses four mapper agents; Serena bridge must emulate sequentially."
        }
      ],
      "flags": [
        {
          "name": "--fast",
          "effects": [
            "writesSubset",
            "usesSingleMapper"
          ],
          "notes": [
            "Reference fast mode performs a lightweight scan and may combine with --focus."
          ]
        },
        {
          "name": "--focus",
          "effects": [
            "narrowsMappingScope"
          ],
          "notes": [
            "Reference focus values include tech, arch, quality, concerns, and tech+arch."
          ]
        },
        {
          "name": "--query",
          "effects": [
            "usesIntelRuntime",
            "maySkipArtifactWrites"
          ],
          "notes": [
            "Reference query/status/diff/refresh modes require intel.enabled configuration."
          ]
        }
      ]
    },
    "new-project": {
      "artifacts": [
        ".planning/PROJECT.md",
        ".planning/REQUIREMENTS.md",
        ".planning/ROADMAP.md",
        ".planning/STATE.md",
        ".planning/config.json"
      ],
      "requiredReads": [
        "README.md"
      ],
      "allowedWrites": [
        ".planning/PROJECT.md",
        ".planning/REQUIREMENTS.md",
        ".planning/ROADMAP.md",
        ".planning/STATE.md",
        ".planning/config.json",
        ".planning/research/**"
      ],
      "forbiddenWrites": [
        ".git/**",
        ".github/**",
        "node_modules/**",
        "vendor/**"
      ],
      "transitions": [
        {
          "from": "init",
          "to": "planned",
          "when": "Project foundation, requirements, roadmap, config, and state artifacts are established.",
          "notes": "Reference research artifacts are optional and may be omitted when no research path runs."
        }
      ],
      "flags": [
        {
          "name": "--auto",
          "effects": [
            "runsResearchRequirementsRoadmapWithoutFurtherInteraction"
          ],
          "notes": [
            "Reference automatic mode runs research, requirements, and roadmap after configuration questions."
          ]
        }
      ]
    },
    "plan-phase": {
      "artifacts": [
        ".planning/phases/<phase>/<phase-number>-PATTERNS.md",
        ".planning/phases/<phase>/PLAN.md"
      ],
      "requiredReads": [
        ".planning/PROJECT.md",
        ".planning/REQUIREMENTS.md",
        ".planning/ROADMAP.md",
        ".planning/phases/<phase>/CONTEXT.md"
      ],
      "allowedWrites": [
        ".planning/phases/<phase>/<phase-number>-PATTERNS.md",
        ".planning/phases/<phase>/CONTEXT.md",
        ".planning/phases/<phase>/PLAN.md",
        ".planning/phases/<phase>/RESEARCH.md",
        ".planning/phases/<phase>/SKELETON.md"
      ],
      "forbiddenWrites": [
        ".git/**",
        ".github/**",
        "node_modules/**",
        "vendor/**"
      ],
      "transitions": [
        {
          "from": "phase-context-ready",
          "to": "phase-planned",
          "when": "The phase plan is written from project context and phase CONTEXT.md.",
          "notes": "Research, PRD, ingest, review, gap, and MVP modes can alter reads or conditional artifacts."
        }
      ],
      "flags": [
        {
          "name": "--auto",
          "effects": [
            "reducesInteractivePrompts"
          ],
          "notes": [
            "Reference argument hint lists automatic planning mode."
          ]
        },
        {
          "name": "--gaps",
          "effects": [
            "plansGapClosure",
            "requiresVerificationInput"
          ],
          "notes": [
            "Reference gap mode reads VERIFICATION.md and skips research."
          ]
        },
        {
          "name": "--ingest",
          "effects": [
            "usesExternalDecisionSource",
            "writesContextFromIngestedInput"
          ],
          "notes": [
            "Reference ingest mode parses ADR-like inputs into CONTEXT.md and skips discuss-phase."
          ]
        },
        {
          "name": "--ingest-format",
          "effects": [
            "selectsIngestParser"
          ],
          "notes": [
            "Reference parser format values include auto, nygard, madr, and narrative."
          ]
        },
        {
          "name": "--mvp",
          "effects": [
            "plansVerticalSlices"
          ],
          "artifactsAdded": [
            ".planning/phases/<phase>/SKELETON.md"
          ],
          "notes": [
            "Reference MVP mode can emit SKELETON.md for Phase 1."
          ]
        },
        {
          "name": "--prd",
          "effects": [
            "usesPrdAsContextSource",
            "writesContextFromPrd"
          ],
          "notes": [
            "Reference PRD mode parses requirements into CONTEXT.md and skips discuss-phase."
          ]
        },
        {
          "name": "--research",
          "effects": [
            "refreshesResearch"
          ],
          "artifactsAdded": [
            ".planning/phases/<phase>/RESEARCH.md"
          ],
          "notes": [
            "Reference force-refreshes phase research before planning."
          ]
        },
        {
          "name": "--research-phase",
          "effects": [
            "writesResearchOnly",
            "skipsPlanWrite"
          ],
          "artifactsAdded": [
            ".planning/phases/<phase>/RESEARCH.md"
          ],
          "artifactsRemoved": [
            ".planning/phases/<phase>/PLAN.md"
          ],
          "notes": [
            "Reference research-only mode exits before the planner runs."
          ]
        },
        {
          "name": "--reviews",
          "effects": [
            "incorporatesReviewFeedback"
          ],
          "notes": [
            "Reference replans with cross-AI review feedback from REVIEWS.md."
          ]
        },
        {
          "name": "--skip-research",
          "effects": [
            "skipsResearch"
          ],
          "notes": [
            "Reference skips research and proceeds directly to planning."
          ]
        },
        {
          "name": "--skip-verify",
          "effects": [
            "skipsVerificationLoop"
          ],
          "notes": [
            "Reference skips the plan verification loop."
          ]
        },
        {
          "name": "--tdd",
          "effects": [
            "prioritizesTestFirstPlan"
          ],
          "notes": [
            "Reference argument hint lists TDD planning mode."
          ]
        },
        {
          "name": "--text",
          "effects": [
            "usesTextInterface"
          ],
          "notes": [
            "Reference uses plain-text numbered lists instead of TUI menus."
          ]
        },
        {
          "name": "--view",
          "effects": [
            "readsResearchOnly",
            "skipsPlanWrite"
          ],
          "notes": [
            "Reference view-only mode prints existing RESEARCH.md and exits."
          ]
        }
      ]
    },
    "ship": {
      "artifacts": [
        ".planning/phases/<phase>/shipping/DIRECT_MAIN_SHIP.md",
        ".planning/phases/<phase>/shipping/RELEASE_NOTES.md",
        ".planning/phases/<phase>/shipping/ROLLBACK.md"
      ],
      "requiredReads": [],
      "allowedWrites": [
        ".planning/phases/<phase>/shipping/**"
      ],
      "forbiddenWrites": [
        ".git/**",
        ".github/**",
        "node_modules/**",
        "vendor/**"
      ],
      "transitions": [
        {
          "from": "shipping-ready",
          "to": "shipped",
          "when": "Verified work is prepared for handoff or release.",
          "notes": "Reference ship workflow includes broader branch, PR, review, and merge-oriented behavior."
        }
      ],
      "flags": []
    },
    "verify-work": {
      "artifacts": [
        ".planning/phases/<phase>/<phase-number>-UAT.md"
      ],
      "requiredReads": [
        ".planning/phases/<phase>/EXECUTION.md",
        ".planning/phases/<phase>/PLAN.md"
      ],
      "allowedWrites": [
        ".planning/phases/<phase>/<phase-number>-UAT.md",
        ".planning/phases/<phase>/UAT.md",
        ".planning/phases/<phase>/gaps/**"
      ],
      "forbiddenWrites": [
        ".git/**",
        ".github/**",
        "node_modules/**",
        "vendor/**"
      ],
      "transitions": [
        {
          "from": "phase-executed",
          "to": "phase-uat-passed",
          "when": "UAT evidence passes without blocking issues.",
          "notes": "If issues are found, reference behavior diagnoses gaps and prepares fix plans instead of advancing directly."
        },
        {
          "from": "phase-executed",
          "to": "gap-closure-ready",
          "when": "UAT or verification finds gaps that require fix plans.",
          "notes": "Gap closure plans feed execute-phase --gaps-only."
        }
      ],
      "flags": [
        {
          "name": "--ws",
          "effects": [
            "targetsWorkstream"
          ],
          "notes": [
            "Reference argument hint lists workstream-specific verification."
          ]
        }
      ]
    }
  }
}
