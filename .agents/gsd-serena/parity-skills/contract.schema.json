{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://serena-gsd-bridge.local/schemas/parity-skill-contract.schema.json",
  "title": "Serena GSD Bridge Parity Skill Contract Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contracts"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contractRow"
      }
    }
  },
  "$defs": {
    "contractFamily": {
      "type": "string",
      "enum": [
        "command",
        "workflow",
        "role",
        "reference",
        "template",
        "context"
      ]
    },
    "contractStatus": {
      "type": "string",
      "enum": [
        "planned",
        "implemented",
        "supported",
        "adapted-safe",
        "manual-fallback",
        "blocked",
        "asset-only"
      ]
    },
    "sourceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "compatibility-matrix",
            "vendor-command",
            "vendor-workflow",
            "vendor-agent",
            "vendor-reference",
            "vendor-template",
            "vendor-context",
            "bridge-command-contract",
            "bridge-command-spec",
            "generated-index"
          ]
        },
        "sourceHash": {
          "type": "string"
        }
      }
    },
    "transitionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "transition",
            "no-transition",
            "planned",
            "manual-fallback",
            "blocked"
          ]
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "requiresValidation": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "transition"
              }
            }
          },
          "then": {
            "required": [
              "from",
              "to",
              "requiresValidation"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "no-transition",
                  "planned",
                  "manual-fallback",
                  "blocked"
                ]
              }
            }
          },
          "then": {
            "required": [
              "reason"
            ]
          }
        }
      ]
    },
    "testEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "commands",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "none",
            "planned",
            "focused-test",
            "package-smoke",
            "manual-evidence"
          ]
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "contractRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "family",
        "status",
        "sourceEvidence",
        "bridgeEntrypoints",
        "requiredReads",
        "allowedWrites",
        "forbiddenWrites",
        "expectedCreatedFiles",
        "expectedUpdatedFiles",
        "optionalFiles",
        "validationCommands",
        "transitionRule",
        "unsafeReferenceBehaviors",
        "testEvidence",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._/-]*$"
        },
        "name": {
          "type": "string"
        },
        "family": {
          "$ref": "#/$defs/contractFamily"
        },
        "status": {
          "$ref": "#/$defs/contractStatus"
        },
        "sourceEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceEvidence"
          }
        },
        "bridgeEntrypoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredReads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowedWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenWrites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expectedCreatedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expectedUpdatedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optionalFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validationCommands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transitionRule": {
          "$ref": "#/$defs/transitionRule"
        },
        "unsafeReferenceBehaviors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "testEvidence": {
          "$ref": "#/$defs/testEvidence"
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "planned",
                  "asset-only"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "transitionRule": {
                "properties": {
                  "kind": {
                    "enum": [
                      "no-transition",
                      "planned"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "blocked"
              }
            }
          },
          "then": {
            "properties": {
              "transitionRule": {
                "properties": {
                  "kind": {
                    "const": "blocked"
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
