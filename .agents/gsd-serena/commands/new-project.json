{
  "schemaVersion": 1,
  "id": "new-project",
  "description": "Initialize planning artifacts for a greenfield project.",
  "requiresPhase": false,
  "defaultRole": "planner",
  "requiredReads": [
    "README.md"
  ],
  "allowedWrites": [
    ".planning/PROJECT.md",
    ".planning/REQUIREMENTS.md",
    ".planning/ROADMAP.md",
    ".planning/STATE.md",
    ".planning/config.json",
    ".planning/research/**"
  ],
  "forbiddenWrites": [
    ".git/**",
    ".github/**",
    "node_modules/**",
    "vendor/**"
  ],
  "expectedArtifacts": [
    ".planning/PROJECT.md",
    ".planning/REQUIREMENTS.md",
    ".planning/ROADMAP.md",
    ".planning/STATE.md",
    ".planning/config.json"
  ],
  "validationCommand": "gsd-serena-bridge validate new-project --format json",
  "transition": {
    "from": "init",
    "to": "planned",
    "requiresValidation": true
  }
}
