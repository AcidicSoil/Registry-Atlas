{
  "schemaVersion": 1,
  "id": "verify-work",
  "description": "Verify executed phase work against acceptance criteria, validation evidence, and remaining risks.",
  "requiresPhase": true,
  "defaultRole": "reviewer",
  "requiredReads": [
    ".planning/phases/<phase>/EXECUTION.md",
    ".planning/phases/<phase>/PLAN.md"
  ],
  "allowedWrites": [
    ".planning/phases/<phase>/<phase-number>-UAT.md",
    ".planning/phases/<phase>/UAT.md",
    ".planning/phases/<phase>/gaps/**"
  ],
  "forbiddenWrites": [
    ".git/**",
    ".github/**",
    "node_modules/**",
    "vendor/**"
  ],
  "expectedArtifacts": [
    ".planning/phases/<phase>/<phase-number>-UAT.md"
  ],
  "validationCommand": "gsd-serena-bridge validate verify-work --phase <phase> --format json",
  "transition": {
    "from": "phase-executed",
    "to": "phase-uat-passed",
    "requiresValidation": true
  }
}
