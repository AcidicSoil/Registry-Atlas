{
  "schemaVersion": 1,
  "id": "map-codebase",
  "description": "Map an existing repository into durable planning artifacts.",
  "requiresPhase": false,
  "defaultRole": "architecture-mapper",
  "requiredReads": [
    ".planning/STATE.md",
    "README.md",
    "package.json"
  ],
  "allowedWrites": [
    ".planning/codebase/**"
  ],
  "forbiddenWrites": [
    ".git/**",
    ".github/**",
    "node_modules/**",
    "vendor/**"
  ],
  "expectedArtifacts": [
    ".planning/codebase/ARCHITECTURE.md",
    ".planning/codebase/CONCERNS.md",
    ".planning/codebase/CONVENTIONS.md",
    ".planning/codebase/INTEGRATIONS.md",
    ".planning/codebase/STACK.md",
    ".planning/codebase/STRUCTURE.md",
    ".planning/codebase/TESTING.md"
  ],
  "validationCommand": "gsd-serena-bridge validate map-codebase --format json",
  "transition": {
    "from": "init",
    "to": "mapped",
    "requiresValidation": true
  }
}
